<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Builder | Seabe Digital</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased pb-20">

    <div class="bg-gray-900 text-white shadow-md">
        <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold"><i class="fa-solid fa-hammer text-blue-400 mr-3"></i>Course Builder</h1>
            <a href="/admin/<%= orgCode %>/academy" class="text-gray-300 hover:text-white transition">...</a>
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 py-8">
       <form action="/admin/<%= orgCode %>/courses" method="POST" id="courseForm">
            
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
                <h2 class="text-xl font-bold text-gray-900 border-b pb-3 mb-4">1. Course Details</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Course Title</label>
                        <input type="text" name="title" required placeholder="e.g., The 5-Day Barber Business Blueprint" 
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Price (ZAR)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-3 text-gray-500 font-bold">R</span>
                            <input type="number" name="price" required placeholder="0.00" step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Set to 0 for a free lead-magnet course.</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
                <div class="flex justify-between items-center border-b pb-3 mb-4">
                    <h2 class="text-xl font-bold text-gray-900">2. Curriculum (The Daily Drip)</h2>
                    <button type="button" onclick="addModule()" class="text-sm bg-blue-50 text-blue-600 font-bold py-2 px-4 rounded-lg hover:bg-blue-100 transition">
                        <i class="fa-solid fa-plus mr-1"></i> Add Day
                    </button>
                </div>

                <div id="modulesContainer" class="space-y-6">
                    <div class="module-card bg-gray-50 rounded-lg p-5 border border-gray-200 relative">
                        <div class="absolute top-4 right-4 bg-gray-800 text-white text-xs font-bold px-2 py-1 rounded day-badge">Day 1</div>
                        
                        <label class="block text-sm font-bold text-gray-700 mb-2">Lesson Title</label>
                        <input type="text" name="moduleTitles[]" required placeholder="e.g., Welcome & The Mindset Shift" class="w-full px-4 py-2 mb-4 rounded border outline-none focus:border-blue-500">
                        
                        <label class="block text-sm font-bold text-gray-700 mb-2">Lesson Text (WhatsApp Body)</label>
                        <textarea name="moduleContents[]" required rows="4" placeholder="Type out the lesson here. Use *bold* or _italics_ for WhatsApp formatting..." class="w-full px-4 py-2 mb-4 rounded border outline-none focus:border-blue-500"></textarea>

                        <label class="block text-sm font-bold text-gray-700 mb-2">Video URL (Optional)</label>
                        <input type="url" name="moduleUrls[]" placeholder="https://example.com/video.mp4" class="w-full px-4 py-2 mb-4 rounded border outline-none focus:border-blue-500 text-sm">

                        <div class="bg-blue-50 p-4 rounded-lg border border-blue-100">
                            <label class="block text-sm font-bold text-blue-900 mb-2"><i class="fa-solid fa-robot mr-1"></i> AI Quiz Question (Optional)</label>
                            <input type="text" name="moduleQuizzes[]" placeholder="What is the most important metric for a barber?" class="w-full px-4 py-2 mb-2 rounded border outline-none focus:border-blue-500 text-sm">
                            
                            <label class="block text-xs font-bold text-blue-700 mb-1">Target Answer (Context for the AI Grader)</label>
                            <input type="text" name="moduleAnswers[]" placeholder="Client retention rate