// ==========================================
// PRISMA SCHEMA - CLEAN VERSION
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER & MEMBERSHIP ---
model Member {
  id                Int       @id @default(autoincrement())
  firstName         String
  lastName          String
  phone             String
  email             String?
  createdAt         DateTime  @default(now())
  monthlyPremium    Float? // <--- ADD THIS LINE
  idType            String?   @default("SA_ID")
  idNumber          String? // Stores ENCRYPTED data (e.g. "a1b2:f9e8...")
  address           String? // Stores ENCRYPTED data
  kycToken          String?   @unique
  kycTokenExpires   DateTime?
  idPhotoUrl        String? // Stores encrypted Cloudinary URL
  proofOfAddressUrl String? // Stores encrypted Cloudinary URL
  isIdVerified      Boolean   @default(false)
  rejectionReason   String?
  verifiedAt        DateTime?
  consecutiveFailures Int @default(0) // 🛡️ Tracks Clause 8.2 (2 Strikes)

// 🚀 NEW: The specific day of the month they want to be billed (1-31)
  collectionDay   Int       @default(1)
  
  // Link 1: Church (Optional)
  churchCode String?
  church     Church? @relation("ChurchMembers", fields: [churchCode], references: [code])

  // Link 2: Burial Society (Optional)
  societyCode String?
  society     Church? @relation("SocietyMembers", fields: [societyCode], references: [code])

  // Society Data
  status       String   @default("ACTIVE")
  policyNumber String?
  joinedAt     DateTime @default(now())

  dependents   Dependent[]
  transactions Transaction[]
  claims       Claim[]
  collections  Collection[]
  riskFlags    RiskFlag[]
  enrollments  Enrollment[]
}

model Dependent {
  id          Int    @id @default(autoincrement())
  firstName   String
  lastName    String
  dateOfBirth String // 👈 Changed from idNumber to dateOfBirth
  relation    String
  status      String @default("ACTIVE")
  memberId    Int
  member      Member @relation(fields: [memberId], references: [id])
}

// --- ORGANIZATIONS ---
model Church {
  id         Int     @id @default(autoincrement())
  code       String  @unique
  name       String
  type       String // "CHURCH" or "BURIAL_SOCIETY"
  adminPhone String?
  email      String? // ✅ Fixed
  password   String?
  mfaSecret  String?
  setupToken String?

  // FICA Level 1 (Initial FICA)
  pastorIdUrl    String? // Cloudinary Vault Link
  proofOfBankUrl String? // Cloudinary Vault Link

  // FICA Level 2 (Corporate FICA)
  npcRegUrl      String?
  cipcDocUrl     String?
  directorIdsUrl String? // Can be an array or single merged PDF link

  // State Machine for FICA Flow
  ficaStatus String @default("LEVEL_1_PENDING")
  // Statuses: LEVEL_1_PENDING -> AWAITING_LEVEL_2 -> LEVEL_2_PENDING -> NETCASH_READY -> ACTIVE

  // Financial Fields
  defaultPremium  Float?  @default(150.0)
  subscriptionFee Float?  @default(0.0) // ✅ Added to match your code
  subaccountCode  String? // ✅ Renamed from 'Subaccount' to match your code

  otp           String?
  otpExpires    DateTime?
  createdAt     DateTime  @default(now())
  tosAcceptedAt DateTime? // 👈 Add this so web.js can save the Terms agreement
  
  // Compliance Tracking
  agencyAccepted    Boolean  @default(false)
  acceptedAt        DateTime?
  acceptedVersion   String?  // e.g., "v1.0-SARB-DIR1-2007"
  acceptedByIp      String?  // For audit log forensic proof
  
  // --- COMPLIANCE ARCHIVE FIELDS ---
  deletedAt       DateTime? // If populated, the record is "soft deleted"
  archived        Boolean  @default(false)
  retentionExpiry DateTime? // Exactly 5 years from createdAt
  

  // Relations
  admins  Admin[]
  courses Course[]

  // Member Relations
  churchMembers  Member[] @relation("ChurchMembers")
  societyMembers Member[] @relation("SocietyMembers")

  transactions   Transaction[]
  ledgerEntries  TransactionLedger[]
  events         Event[]
  claims         Claim[]
  ads            Ad[]
  news           News[]
  // Procurement Relations
  vendors        Vendor[]
  rfqs           RequestForQuote[]
  purchaseOrders PurchaseOrder[]

  // 📋 Dynamic Policy Relations
  plans  PolicyPlan[]
  addons PolicyAddon[]
}

enum OrgType {
  CHURCH
  BURIAL_SOCIETY
  NON_PROFIT
  SERVICE_PROVIDER
}

// --- FINANCES & CONTENT ---
model Transaction {
  id              Int      @id @default(autoincrement())
  churchCode      String
  church          Church   @relation(fields: [churchCode], references: [code])
  phone           String   // Keep this for easy Twilio replies
  memberId        Int?     // Link to the specific member profile
  member          Member?  @relation(fields: [memberId], references: [id])
  type            String   // OFFERING, TITHE, PREM, TICKET
  
  // 💰 THE 4-PILLAR LEDGER (For Segregation & Auditing)
  amount          Float    // 1. Gross Amount (What the user's card was charged, e.g., R150)
  netcashFee      Float?   // 2. Gateway Fee (What Netcash deducts, e.g., R2.50)
  platformFee     Float?   // 3. Seabe Fee (Your revenue, e.g., R5.00)
  netSettlement   Float?   // 4. Church Payout (What physically lands in their bank, e.g., R142.50)
  
  reference       String   @unique
  status          String   @default("PENDING") // 👈 Default set to uppercase PENDING
  method          String?  // CARD, EFT, CASH
  description     String?
  date            DateTime @default(now())
  
  // 💸 PAYOUT RELATION (To track if this money has been settled)
  payoutId      Int?
  payoutBatch   PayoutLog? @relation(fields: [payoutId], references: [id])

  // 🛡️ COMPLIANCE RELATION (Links to the AML Risk Engine)
  complianceLog   ComplianceLog?
  gateway         String?   @default("NETCASH") // "PAYFAST" or "NETCASH"

// --- ADD THESE 3 LINES FOR SARB COMPLIANCE ---
  deletedAt       DateTime? 
  archived        Boolean   @default(false)
  retentionExpiry DateTime?

}

model Event {
  id          Int      @id @default(autoincrement())
  churchCode  String
  church      Church   @relation(fields: [churchCode], references: [code])
  name        String
  date        String
  price       Float
  isDonation  Boolean  @default(false) // 👈 This powers the "Any Amount" logic
  description String?
  status      String   @default("Active")
  expiryDate  DateTime
}

model News {
  id         Int      @id @default(autoincrement())
  headline   String
  body       String?
  status     String   @default("Active")
  expiryDate DateTime
  createdAt  DateTime @default(now())

  churchId Int    @default(1)
  church   Church @relation(fields: [churchId], references: [id])
}

model Ad {
  id         Int      @id @default(autoincrement())
  churchId   Int
  church     Church   @relation(fields: [churchId], references: [id])
  content    String
  imageUrl   String? // 🟢 RE-ADD THIS to prevent crashes
  isPlatform Boolean  @default(false)
  views      Int      @default(0)
  status     String   @default("Active")
  expiryDate DateTime
  createdAt  DateTime @default(now())
}

model Claim {
  id Int @id @default(autoincrement())

  // Link to Church
  churchCode String
  church     Church @relation(fields: [churchCode], references: [code])

  // Link to Member
  memberId Int?
  member   Member? @relation(fields: [memberId], references: [id])

  beneficiaryName String
  payoutAmount    Float
  status          String @default("PENDING") // PENDING, APPROVED, PAID, DECLINED

  // --------------------------------------------------
  // ✨ NEW AI & DOCUMENT FIELDS (REQUIRED FOR ADMIN UI)
  // --------------------------------------------------
  deceasedIdNumber String?
  dateOfDeath      DateTime?
  causeOfDeath     String?
  claimantPhone    String?
  documentUrl      String?
  adminNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String?
  role      String   @default("STAFF")
  church    Church   @relation(fields: [churchId], references: [id])
  churchId  Int
  createdAt DateTime @default(now())
}

model Collection {
  id         Int      @id @default(autoincrement())
  churchCode String
  firstName  String
  lastName   String?
  phone      String
  email      String?
  amount     Float
  reference  String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  memberId Int?
  member   Member? @relation(fields: [memberId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String // The ID of the admin or system process making the change
  action    String // e.g., 'CREATE', 'UPDATE', 'DELETE'
  modelName String // The table being modified (e.g., 'Collection', 'Member', 'Policy')
  recordId  String // The specific ID of the row being altered
  oldData   Json? // A complete snapshot of the row BEFORE the change
  newData   Json? // A complete snapshot of the row AFTER the change
  ipAddress String? // (Optional) Track the network location of the admin
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([modelName, recordId])
}

model RiskFlag {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  flagType    String // "VELOCITY_SPIKE", "DUPLICATE_CLAIM", "FICA_EXPIRED"
  severity    String // "LOW", "MEDIUM", "CRITICAL"
  description String // e.g., "User paid from 3 different IPs in 24 hours"
  status      String @default("OPEN") // OPEN, INVESTIGATING, RESOLVED

  createdAt DateTime @default(now())
}

// ==========================================
// 🛒 PROCUREMENT & VENDOR MODULE
// ==========================================

model Vendor {
  id             Int             @id @default(autoincrement())
  churchId       Int
  church         Church          @relation(fields: [churchId], references: [id])
  name           String
  category       String // e.g., Catering, Tent Hire, Venue, Florist
  phone          String // For WhatsApp RFQs
  email          String?
  bankDetails    String?
  status         String          @default("ACTIVE")
  purchaseOrders PurchaseOrder[]
  quotes         Quote[]
  createdAt      DateTime        @default(now())
}

model RequestForQuote {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  title       String
  description String   @db.Text
  requiredBy  DateTime
  status      String   @default("OPEN") // OPEN, CLOSED, FULFILLED
  quotes      Quote[]
  createdAt   DateTime @default(now())
}

model Quote {
  id        Int             @id @default(autoincrement())
  rfqId     Int
  rfq       RequestForQuote @relation(fields: [rfqId], references: [id])
  vendorId  Int
  vendor    Vendor          @relation(fields: [vendorId], references: [id])
  amount    Float
  notes     String?         @db.Text
  status    String          @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime        @default(now())
}

model PurchaseOrder {
  id        Int      @id @default(autoincrement())
  poNumber  String   @unique
  churchId  Int
  church    Church   @relation(fields: [churchId], references: [id])
  vendorId  Int
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  amount    Float
  lineItems String   @db.Text // Storing as text/JSON string to avoid DB strictness
  status    String   @default("ISSUED") // ISSUED, FULFILLED, PAID
  createdAt DateTime @default(now())
}

// ==========================================
// 📋 DYNAMIC POLICY PLANS
// ==========================================

model PolicyPlan {
  id              Int      @id @default(autoincrement())
  churchId        Int
  church          Church   @relation(fields: [churchId], references: [id])
  planName        String // e.g., "Plan A"
  targetGroup     String // e.g., "Single Member", "Principal + Spouse + 6 Children"
  monthlyPremium  Float // e.g., 160.00
  benefitsSummary String   @db.Text // e.g., "Grocery + Vegetables + 2 Sheep + R500 Cash"
  createdAt       DateTime @default(now())

  joiningFee  Float?
  coverAmount Float?
  maxMembers  Int?
}

model PolicyAddon {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  addonName   String // e.g., "Additional Child", "Additional Adult"
  monthlyCost Float // e.g., 20.00, 30.00
  createdAt   DateTime @default(now())
}

// ==========================================
// 🎓 LMS / COURSE BUILDER MODELS (UPDATED)
// ==========================================

model Course {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  price       Decimal   @default(0.0)
  status      String    @default("DRAFT") // DRAFT, LIVE, ARCHIVED
  code        String?   
  
  // Relations
  churchId    Int?
  church      Church?   @relation(fields: [churchId], references: [id])
  
  modules     Module[]
  enrollments Enrollment[]
  
  createdAt   DateTime  @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Module {
  id          Int      @id @default(autoincrement())
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  title       String
  order       Int      @default(1)
  type        String   @default("TEXT")  // TEXT, PDF, VIDEO, AUDIO
  
  // 🚀 CONTENT FIELDS (Fixed based on Error Logs)
  content         String?  // The generic/summary content
  dailyLessonText String?  // The full detailed lesson text
  
  // 🚀 QUIZ FIELDS (New)
  quizQuestion    String?
  quizAnswer      String?
  
  contentUrl      String?  // Cloudinary Link
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id])
  
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])
  
  progress  Int      @default(0) // Last Module Order Sent
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
  
  // 🚀 STATE MACHINE (New)
  quizState String   @default("IDLE") // IDLE, AWAITING_ANSWER
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotSession {
  phone     String   @id
  step      String?
  mode      String?
  data      Json?    @default("{}")
  updatedAt DateTime @updatedAt
}

// 1. Strict Categorization for the Ledger
enum TxModule {
  SUREPOL_PREMIUM // Burial Society Collections
  CHURCH_TITHE // General church donations
  LMS_COURSE // AI Discipleship/Course purchases
  EVENT_TICKET // Event bookings
  RESTAURANT_BILL // Table-side QR payments
  RETAIL_ORDER // Conversational commerce
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// 2. The Master Ledger (The Source of Truth)
model TransactionLedger {
  id         String @id @default(uuid())
  netcashRef String @unique // The exact reference generated for Netcash
  amount     Float // Total amount paid by customer
  seabeFee   Float? // Your calculated margin (e.g., the R1.50 + 2.5%)

  status TxStatus @default(PENDING)
  module TxModule // What product generated this sale?

  // 3. The Merchant Link (Who gets the money?)
  churchId Int // Links back to the Church/Restaurant/Society
  church   Church @relation(fields: [churchId], references: [id])

  // 4. The Context Links (Optional connections to specific modules)
  collectionId Int?    @unique // If it was a Surepol debt collection
  eventId      Int? // If it was an event ticket
  courseId     Int? // If it was an LMS course
  orderId      String? // If it was a restaurant/retail order

  // Audit Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  settledAt DateTime? // When the money actually cleared to the merchant's bank
}

// 💰 NEW: Dynamic Pricing Catalog
model ServicePrice {
  id          Int      @id @default(autoincrement())
  code        String   @unique  // e.g. "KYC_CHECK", "CLAIM_AI", "SMS_NOTIF"
  amount      Decimal  @default(0.00)
  description String?
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 🛡️ COMPLIANCE & AUDIT MODELS
// ==========================================

model ComplianceLog {
  id              String   @id @default(uuid())
  transactionId   Int      @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  riskScore       Float    // 0.0 to 1.0
  isPepFound      Boolean  @default(false)
  isSanctionHit   Boolean  @default(false)
  isCtrTriggered  Boolean  @default(false) // Cash Threshold Report (>R49,999)
  status          String   // 'CLEARED', 'FLAGGED', 'BLOCKED'
  adminNotes      String?
  createdAt       DateTime @default(now())
}

// ⚙️ DYNAMIC FEE CONFIGURATION
model FeeConfiguration {
  id          Int      @id @default(autoincrement())
  provider    String   // 'NETCASH', 'OZOW'
  method      String   // 'CARD', 'EFT', 'CASH'
  
  // Cost Structure (What they charge YOU)
  baseFee     Float    // Fixed cost (e.g., R2.00)
  percentFee  Float    // Percentage (e.g., 2.5%)
  
  // Revenue Structure (What YOU charge the church)
  seabeFixed  Float    @default(5.00) // Your flat markup
  seabePercent Float   @default(0.0)  // Your % markup (if applicable)
  
  isActive    Boolean  @default(true) // Easy switch to turn off old rates
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Optional: Link to specific churches if you negotiate custom rates
  // churches Church[] 
}

// ==========================================
// 💸 PAYOUT & SETTLEMENT LOGGING
// ==========================================
model PayoutLog {
  id          Int      @id @default(autoincrement())
  churchCode  String   // Which org got paid
  amount      Float    // The total netSettlement paid out
  txCount     Int      // How many transactions this covers
  reference   String   @unique // Generated unique ID (e.g. PAY-AFM-1234)
  status      String   // 'COMPLETED', 'FAILED'
  adminId     String   // Who clicked the button
  createdAt   DateTime @default(now())

  // A payout is made up of many transactions
  transactions Transaction[]
}


